{
  "identifier": "git-manager",
  "description": "Capability for the git manager widget window",
  "windows": ["git-manager"],
  "webviews": ["git-manager"],
  "permissions": [
    "core:default",
    "core:window:default",
    "core:window:allow-close",
    "core:window:allow-start-dragging",
    "core:window:allow-set-focus",
    "core:window:allow-set-effects",
    "core:window:allow-set-size",
    "core:event:default",
    "core:event:allow-listen"
  ]
}
