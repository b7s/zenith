{
  "identifier": "rename",
  "description": "Capability for the rename input window",
  "windows": ["rename-*"],
  "webviews": ["rename-*"],
  "permissions": [
    "core:default",
    "core:window:default",
    "core:window:allow-close",
    "core:window:allow-set-focus",
    "core:window:allow-set-effects",
    "core:event:default",
    "core:event:allow-listen"
  ]
}
