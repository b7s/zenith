{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-config-schema/schema.json",
  "productName": "Zenith",
  "version": "0.1.13",
  "identifier": "com.zenith.bar",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1422",
    "frontendDist": "../dist",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "bar",
        "title": "Zenith",
        "url": "src/windows/bar/index.html",
        "width": 1920,
        "height": 40,
        "x": 0,
        "y": 0,
        "resizable": false,
        "minimizable": false,
        "maximizable": false,
        "closable": false,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": false,
        "skipTaskbar": true,
        "focus": false,
        "focusable": false,
        "visible": false,
        "center": false,
        "shadow": false,
        "additionalBrowserArgs": "--default-background-color=00000000"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "nsis",
    "resources": ["../widgets/"],
    "createUpdaterArtifacts": true,
    "windows": {
      "nsis": {
        "installMode": "currentUser"
      }
    },
    "icon": [
      "icons/defaults/icon-dark.png",
      "icons/defaults/icon-light.png"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEI3QUI1MUNFQzAwRTRGNDkKUldSSlR3N0F6bEdydDZFSThDS3FRNnlZY3NMMXJBdUFKTmxqS3JhVFdITkMyNTJQWWw5clBIQ2EK",
      "endpoints": ["https://github.com/b7s/zenith/releases/latest/download/latest.json"],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
